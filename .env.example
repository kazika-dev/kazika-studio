
# Google Gemini API Key
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_strong_random_secret
AUTH_TRUST_HOST=true
# Signup is disabled unless explicitly enabled. When enabled, SIGNUP_INVITE_CODE is required.
AUTH_SIGNUP_ENABLED=false
SIGNUP_INVITE_CODE=replace_with_a_private_invite_code
# Used by /api/cron/* endpoints. Generate with: openssl rand -base64 32
CRON_SECRET=replace_with_a_strong_random_cron_secret

# Database (Neon/Postgres Direct Connection)
# Prefer Neon pooled connection string for serverless deployments.
# Example: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Optional aliases. Used only when DATABASE_URL is not set.
NEON_DB=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Optional component-based config. Used only when connection-string variables are not set.
DB_HOST=ep-xxx-pooler.region.aws.neon.tech
DB_NAME=neondb
DB_USER=your_neon_user
DB_PASSWORD=your_neon_password
DB_PORT=5432
DB_SSL=true

# GCP Storage Configuration
# Get your service account key from GCP Console (IAM & Admin > Service Accounts)
# The key should be a JSON string (minified, without line breaks)
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# GCP Storage Bucket Name
GCP_STORAGE_BUCKET=your-bucket-name

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Vertex AI Configuration (Optional - uses GCP_SERVICE_ACCOUNT_KEY for authentication)
# Set these to enable Vertex AI models (Gemini 3 Pro)
# GOOGLE_CLOUD_PROJECT is automatically extracted from GCP_SERVICE_ACCOUNT_KEY if not set
GOOGLE_CLOUD_LOCATION=asia-northeast1

# Anthropic API Key (Claude models)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
